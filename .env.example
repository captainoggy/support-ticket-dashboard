# Copy to server/.env for local development.
# All values below are local-development defaults, no real secrets.

# PostgreSQL connection (matches docker-compose db service on host port 5433)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ticketdash"

# Secret used to sign JWTs. Any long random string; required in production.
JWT_SECRET="dev-only-change-me-in-production-0123456789"

# Port the API listens on
PORT=4000

# Comma-separated origins allowed by CORS (Vite dev server + dockerized web)
CLIENT_ORIGINS="http://localhost:5173,http://localhost:8080"

# Password for the seeded demo users (admin@demo.dev / agent@demo.dev).
# Never committed. Reviewers receive the value separately; pick any value locally.
DEMO_PASSWORD=""
